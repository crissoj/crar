{
  "name": "tiarg/correoargentino",
  "description": "This module enables Correo Argentino to work with Prestashop",
  "authors": [
    {
      "name": "Frank Ruiz",
      "email": "frank.ruiz.ar@gmail.com"
    }
  ],
  "require": {
    "php": "^7.1.3",
    "php-parallel-lint/php-parallel-lint": "1.3.2",
    "friendsofphp/php-cs-fixer": "3.3.0",
    "phpstan/phpstan": "1.9.2",
    "prestashop/header-stamp": "2.2"
  },
  "config": {
    "preferred-install": "dist",
    "prepend-autoloader": false
  },
  "autoload": {
    "psr-4": {
      "CorreoArgentino\\": "src/",
      "CorreoArgentino\\Exceptions\\": "src/Exceptions",
      "CorreoArgentino\\Services\\": "src/Services",
      "CorreoArgentino\\Interfaces\\": "src/Interfaces",
      "CorreoArgentino\\Repository\\": "src/Repository",
      "CorreoArgentino\\Utils\\": "src/Util"
    },
    "classmap": [
      "classes",
      "controllers",
      "correoargentino.php"
    ],
    "exclude-from-classmap": []
  },
  "type": "prestashop-module"
}
